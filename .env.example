# NexusRAG configuration — copy to .env and adjust. All values below are the
# safe defaults read by src/nexusrag/config.py. .env is git-ignored; never
# commit real secrets.

# --- LLM (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2:3b

# --- Embeddings ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Pinned HuggingFace revision for the default model (supply-chain reproducibility).
EMBEDDING_REVISION=5c38ec7c405ec4b44b94cc5a9bb96e735b38267a
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# --- Ingestion (chunking) ---
INGESTION_CHUNK_SIZE=1200
INGESTION_CHUNK_OVERLAP=300
INGESTION_MIN_CHUNK_SIZE=200

# --- Retrieval ---
RETRIEVAL_TOP_K=8
RETRIEVAL_RERANK_TOP_K=4
RETRIEVAL_SIMILARITY_THRESHOLD=0.2
RETRIEVAL_MAX_QUERY_LENGTH=512

# --- Corrective re-retrieval / grounding ---
SELF_CORRECTION_ENABLED=true
SELF_CORRECTION_CONFIDENCE_TAU=0.55
SELF_CORRECTION_FEEDBACK_DOCS=5
SELF_CORRECTION_FEEDBACK_TERMS=10
SELF_CORRECTION_GROUNDING_ENABLED=false
SELF_CORRECTION_GROUNDING_MODEL=cross-encoder/nli-deberta-v3-small
SELF_CORRECTION_GROUNDING_THRESHOLD=0.5

# --- API server ---
API_HOST=127.0.0.1
API_PORT=8000
# Comma/JSON list of allowed CORS origins. Never use ["*"] with credentials.
API_CORS_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]
# Leave empty for local (open) use. Set a strong random value for any
# network-exposed deployment to require the X-API-Key header on /api routes.
# Setting a key also auto-disables /docs and /redoc.
NEXUSRAG_API_KEY=
# Interactive docs (/docs, /redoc). Auto-off when NEXUSRAG_API_KEY is set.
API_DOCS_ENABLED=true
# Per-IP rate limits (requests/minute) on /query and /ingest.
API_QUERY_RATE_PER_MINUTE=60
API_UPLOAD_RATE_PER_MINUTE=10
# Upload guards: max raw upload size and max DOCX decompressed size (MB).
API_MAX_UPLOAD_MB=50
API_MAX_UNCOMPRESSED_MB=200

# --- Storage / misc ---
LANCEDB_PATH=./data/lancedb
DATA_DIR=./data
LOG_LEVEL=INFO
